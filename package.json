{
  "name": "diffinity",
  "version": "0.1.0",
  "description": "Semantic DOM diffing engine — capture, compare, and report visual regressions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:report",
    "build:lib": "tsup",
    "build:report": "vite build",
    "dev:report": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "purgecss": "^8.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": false
    }
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "preact": "^10.25.0",
    "playwright": "1.57.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.2"
  }
}
